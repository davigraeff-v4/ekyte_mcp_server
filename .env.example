# Ekyte MCP Server — Configuração
# Apenas 2 variáveis obrigatórias + 2 opcionais

# Bearer Token master do Ekyte (token admin)
EKYTE_BEARER_TOKEN=seu_bearer_token_aqui

# Company ID da sua empresa no Ekyte
EKYTE_COMPANY_ID=9312

# Transporte: 'http' para servidor remoto (EasyPanel), 'stdio' para local
TRANSPORT=http

# Porta do servidor (padrão: 3000)
PORT=3000
