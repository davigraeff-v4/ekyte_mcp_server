# Ekyte MCP Server — configuração
# 2 variáveis obrigatórias + 2 opcionais.
# Auth é só JWT Bearer (o mesmo que o front app.ekyte.com envia).

# JWT Bearer do Ekyte — copie do DevTools → Network → header Authorization
EKYTE_BEARER_TOKEN=

# ID numérico da empresa (visível na URL /api/companies/XXXX/...)
EKYTE_COMPANY_ID=

# Transporte: 'http' para EasyPanel/servidor remoto, 'stdio' para Claude Desktop local
TRANSPORT=stdio

# Porta do servidor HTTP (default: 3000)
PORT=3000
